    "kind": 2,
    "language": "sparql",
    "value": "PREFIX orkgr: <http://orkg.org/orkg/resource/>\nPREFIX orkgc: <http://orkg.org/orkg/class/>\nPREFIX orkgp: <http://orkg.org/orkg/predicate/>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n\nSELECT ?year\n       ?research_paradigm ?research_paradigmLabel\n       ?data_type ?data_typeLabel\n       ?analysis_strategy\n       (COUNT(DISTINCT ?paper) AS ?paper_count)\nWHERE {\n    ?paper orkgp:P31 ?contribution ;\n           orkgp:P29 ?year .\n\n    ?contribution a orkgc:C27001 ;\n                  orkgp:P135046 ?venue ;\n                  orkgp:P57003 ?research_paradigm ;\n                  orkgp:P56008 ?data_collection ;\n                  orkgp:P15124 ?data_analysis .\n\n    ?venue rdfs:label ?venue_name .\n    ?data_collection rdfs:label ?dc_label ;\n                     orkgp:DATA ?research_data .\n    ?data_analysis rdfs:label ?da_label .\n\n    ?research_data orkgp:P7055 ?data_type .\n\n    OPTIONAL { ?research_paradigm rdfs:label ?research_paradigmLabel . }\n    OPTIONAL { ?data_type rdfs:label ?data_typeLabel . }\n\n    {\n        ?data_analysis orkgp:P56043 ?inferential_statistics .\n        BIND(\"inferential statistics\"^^xsd:string AS ?analysis_strategy)\n    }\n    UNION\n    {\n        ?data_analysis orkgp:P56048 ?descriptive_statistic .\n        BIND(\"descriptive statistic\"^^xsd:string AS ?analysis_strategy)\n    }\n    UNION\n    {\n        ?data_analysis orkgp:P57016 ?machine_learning .\n        BIND(\"machine learning\"^^xsd:string AS ?analysis_strategy)\n    }\n\n    FILTER(?dc_label != \"no collection\"^^xsd:string)\n    FILTER(?da_label != \"no analysis\"^^xsd:string)\n    FILTER(?venue_name = \"IEEE International Requirements Engineering Conference\"^^xsd:string)\n}\nGROUP BY ?year ?research_paradigm ?research_paradigmLabel ?data_type ?data_typeLabel ?analysis_strategy\nORDER BY ?year DESC(?paper_count) ?research_paradigmLabel ?data_typeLabel ?analysis_strategy",
    "metadata": {}
  },
