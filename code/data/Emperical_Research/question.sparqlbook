  {
    "kind": 2,
    "language": "sparql",
    "value": "PREFIX orkgr: <http://orkg.org/orkg/resource/>\nPREFIX orkgc: <http://orkg.org/orkg/class/>\nPREFIX orkgp: <http://orkg.org/orkg/predicate/>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n\nSELECT ?question_type ?question_typeLabel\n       ?method_type ?method_typeLabel\n       (COUNT(DISTINCT ?paper) AS ?paper_count)\nWHERE {\n    {\n        SELECT DISTINCT ?paper ?paperLabel ?question_type ?question_typeLabel ?method_type ?method_typeLabel\n        WHERE {\n            ?paper orkgp:P31 ?contribution .\n\n            OPTIONAL { ?paper rdfs:label ?paperLabel . }\n\n            ?contribution a orkgc:C27001 ;\n                          orkgp:P135046 ?venue ;\n                          orkgp:P37330 ?research_question ;\n                          orkgp:P56008 ?data_collection .\n\n            ?venue rdfs:label ?venue_name .\n\n            ?research_question orkgp:P41928 ?question_type .\n            ?data_collection rdfs:label ?dc_label ;\n                             orkgp:P1005 ?dc_method .\n            ?dc_method orkgp:P94003 ?method_type .\n\n            OPTIONAL { ?question_type rdfs:label ?question_typeLabel . }\n            OPTIONAL { ?method_type rdfs:label ?method_typeLabel . }\n\n            FILTER(?dc_label != \"no collection\"^^xsd:string)\n            FILTER(?venue_name = \"IEEE International Requirements Engineering Conference\"^^xsd:string)\n        }\n    }\n}\nGROUP BY ?question_type ?question_typeLabel ?method_type ?method_typeLabel\nORDER BY DESC(?paper_count) ?question_typeLabel ?method_typeLabel",
    "metadata": {}
  }
]