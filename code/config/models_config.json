{
  "api_url_base": "https://api-inference.huggingface.co/models/",
  "models_to_test": [
    {
      "name": "Qwen3-0.6B",
      "id": "Qwen/Qwen3-0.6B",
      "provider": "huggingface",
      "adapter_subdir": "finetuned/Qwen_Qwen3-0.6B__TrainDataset_V1",
      "params": {
        "max_new_tokens": 400,
        "do_sample": false
      },
      "training": {
        "mode": "sft",
        "task_type": "causal_lm",
        "dataset_format": "prompt_completion",
        "max_length": 1024,
        "num_train_epochs": 3,
        "learning_rate": 0.0002,
        "per_device_train_batch_size": 1,
        "per_device_eval_batch_size": 1,
        "gradient_accumulation_steps": 8,
        "warmup_ratio": 0.05,
        "logging_steps": 10,
        "save_total_limit": 2,
        "early_stopping_patience": 2,
        "lora_r": 16,
        "lora_alpha": 32,
        "lora_dropout": 0.05,
        "lora_target_modules": [
          "q_proj",
          "k_proj",
          "v_proj",
          "o_proj",
          "gate_proj",
          "up_proj",
          "down_proj"
        ]
      }
    },
    {
      "name": "Qwen-2.5-7B",
      "id": "Qwen/Qwen2.5-7B-Instruct",
      "provider": "huggingface",
      "params": { 
        "max_new_tokens": 500, 
        "temperature": 0.1,
        "top_p": 0.9
      }
    },
    {
      "name": "GPT-4o-Mini",
      "id": "gpt-4o-mini", 
      "provider": "openai",
      "params": {
        "max_new_tokens": 500,
        "temperature": 0.0
      }
    }
  ]
}