@prefix : <http://example.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

:John foaf:name "John" .
:John foaf:knows :Tim .
:Tim foaf:name "Tim" .
:John rdf:type foaf:Person .
:Tim rdf:type foaf:Person .
:Book1 rdf:type foaf:Document .